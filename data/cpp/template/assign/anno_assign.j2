{%- if is_initializer -%}
{% if 'Embed::static' in annotations %}static {% endif %}{{ var_type }} {{ receiver }}{% if value %}{{ '{' + value[(var_type | length) + 1:-1] + '}' }}{% endif %};
{%- else -%}
